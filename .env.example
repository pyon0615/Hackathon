# Copy this file to .env.local for local overrides (never commit .env.local)
# Set this in Vercel → Project → Settings → Environment Variables

# URL of the deployed Flask backend (no trailing slash)
# Local dev default (http://127.0.0.1:8000) is used when this is unset
VITE_API_URL=https://your-backend-url.onrender.com

# Anthropic API key — required for Step 6 AI narrative (pip install anthropic on the backend)
ANTHROPIC_API_KEY=sk-ant-...
